# Copy to .env and adjust. All values have safe defaults; nothing is required
# for the core offline service to boot.

# --- Database (defaults match docker-compose) ---
PGUSER=memory
PGPASSWORD=memory
PGDATABASE=memory

# --- Optional bearer auth ---
# Leave empty/unset to disable auth entirely. /health stays open regardless.
MEMORY_AUTH_TOKEN=

# --- Optional LLM extraction (phase 2; core works fully without it) ---
# Extraction is provider-agnostic. Set one or more keys to enable the LLM path;
# set nothing and extraction uses deterministic rules (still typed memories, no
# network). LLM_PROVIDER=auto tries configured keys in this order:
# Gemini -> Anthropic -> OpenAI -> offline rules.
#
#   Gemini (default/primary):  GEMINI_API_KEY (GOOGLE_API_KEY also accepted)
#   Anthropic:                 ANTHROPIC_API_KEY
#   OpenAI:                    OPENAI_API_KEY
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Force a provider (auto|gemini|anthropic|openai|none) and/or model id. Leave
# LLM_MODEL blank to use the provider defaults below. Gemini uses its evergreen
# alias so deployments follow the current Flash release without code changes.
# API keys are sent in request headers, never URL query strings.
#
#   Gemini:    gemini-flash-latest (currently Gemini 3.5 Flash)
#   Anthropic: claude-haiku-4-5
#   OpenAI:    gpt-5-mini
#
# In a forced provider mode, LLM_MODEL applies to that provider and LLM_TIMEOUT
# is its per-call budget. In auto mode, LLM_MODEL applies only to the first
# configured provider; failover attempts use their provider defaults so a
# provider-specific model id is never sent elsewhere. Auto-mode attempts divide
# LLM_AUTO_TOTAL_TIMEOUT across configured providers, capped by LLM_TIMEOUT.
# This leaves time for embedding and the DB transaction inside /turns' 60s
# challenge timeout.
LLM_PROVIDER=auto
LLM_MODEL=
LLM_TIMEOUT=25
LLM_AUTO_TOTAL_TIMEOUT=45

# --- Request hardening (optional overrides) ---
# Oversized bodies are rejected with HTTP 413 before JSON parsing.
MAX_REQUEST_BODY_BYTES=1048576

# --- Recall tuning overrides (defaults are the locked v1.0 values) ---
SEM_TOP_N=20
KW_TOP_N=20
RRF_K=60
RECALL_MIN_SCORE=0.55
TIER3_RECENT_N=5
RECALL_SNIPPET_MAX=240
SUPERSESSION_SIM_THRESHOLD=0.92
