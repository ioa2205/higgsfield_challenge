# Copy to .env and adjust. All values have safe defaults; nothing is required
# for the core offline service to boot.

# --- Database (defaults match docker-compose) ---
PGUSER=memory
PGPASSWORD=memory
PGDATABASE=memory

# --- Optional bearer auth ---
# Leave empty/unset to disable auth entirely. /health stays open regardless.
MEMORY_AUTH_TOKEN=

# --- Optional LLM extraction (phase 2; core works fully without it) ---
# Extraction is provider-agnostic. Set ONE key and the LLM path turns on; set
# nothing and extraction uses the deterministic rule path (still typed memories,
# no network). LLM_PROVIDER defaults to "auto" = whichever key below is present.
#
#   Gemini (default/primary):  GEMINI_API_KEY (GOOGLE_API_KEY also accepted)
#   Anthropic:                 ANTHROPIC_API_KEY
#   OpenAI:                    OPENAI_API_KEY
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Force a provider (auto|gemini|anthropic|openai|none) and/or model id. Leave
# LLM_MODEL blank to use a current per-provider default. LLM_TIMEOUT is the
# per-call safety-net budget in seconds (inside the 60s /turns budget).
LLM_PROVIDER=auto
LLM_MODEL=
LLM_TIMEOUT=25

# --- Request hardening (optional overrides) ---
# Oversized bodies are rejected with HTTP 413 before JSON parsing.
MAX_REQUEST_BODY_BYTES=1048576

# --- Recall tuning overrides (defaults are the locked v1.0 values) ---
SEM_TOP_N=20
KW_TOP_N=20
RRF_K=60
RECALL_MIN_SCORE=0.55
TIER3_RECENT_N=5
RECALL_SNIPPET_MAX=240
SUPERSESSION_SIM_THRESHOLD=0.92
